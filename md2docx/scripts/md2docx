#!/bin/bash
# md2docx - Convert markdown to Word with citations and cross-references
#
# Usage:
#   md2docx input.md             → produces input.docx in the same directory
#   md2docx input.md output.docx → produces output.docx at the specified path
#
# Requires a references.bib in the same directory as the input file.

if [ -z "$1" ]; then
    echo "Usage: md2docx input.md [output.docx]"
    exit 1
fi

INPUT="$1"
OUTPUT="${2:-${INPUT%.md}.docx}"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
TEMPLATE="$SCRIPT_DIR/../assets/template.docx"
CSL="$SCRIPT_DIR/../assets/citation-style.csl"
LUA_FILTER="$SCRIPT_DIR/growthlabbify.lua"

INPUT_DIR="$(dirname "$INPUT")"
BIB="$INPUT_DIR/references.bib"

# Check if local bib file exists
if [ ! -f "$BIB" ]; then
    echo "Error: No references.bib found in $INPUT_DIR"
    echo "Please create or copy a references.bib file to the same directory as your markdown file."
    exit 1
fi

# Check if template exists, use it if available
if [ -f "$TEMPLATE" ]; then
    TEMPLATE_ARG="--reference-doc=$TEMPLATE"
else
    TEMPLATE_ARG=""
    echo "Note: No template found at $TEMPLATE, using default formatting"
fi

pandoc "$INPUT" \
  --from=markdown \
  --to=docx \
  $TEMPLATE_ARG \
  --bibliography="$BIB" \
  --filter pandoc-crossref \
  --citeproc \
  --csl="$CSL" \
  --number-sections \
  --toc \
  --toc-depth=3 \
  --lua-filter="$LUA_FILTER" \
  -o "$OUTPUT"

echo "Created: $OUTPUT"
